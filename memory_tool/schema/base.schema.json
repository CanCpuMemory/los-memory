{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://los-memory.local/schemas/base.schema.json",
  "title": "Base Response Schema",
  "description": "Base schema for all los-memory CLI responses",
  "version": "1.0.0",
  "type": "object",
  "required": ["ok", "meta"],
  "properties": {
    "ok": {
      "type": "boolean",
      "description": "Indicates if the operation was successful"
    },
    "data": {
      "description": "Response data (present when ok=true)"
    },
    "error": {
      "description": "Error details (present when ok=false)",
      "$ref": "#/definitions/error"
    },
    "meta": {
      "type": "object",
      "description": "Metadata about the response",
      "required": ["timestamp", "schema_version"],
      "properties": {
        "profile": {
          "type": "string",
          "description": "Profile used (claude, codex, shared)",
          "enum": ["claude", "codex", "shared"]
        },
        "db_path": {
          "type": "string",
          "description": "Path to the database file"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of the response"
        },
        "schema_version": {
          "type": "string",
          "description": "Schema version for compatibility",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "query_time_ms": {
          "type": "integer",
          "description": "Query execution time in milliseconds",
          "minimum": 0
        },
        "pagination": {
          "type": "object",
          "description": "Pagination information for list responses",
          "properties": {
            "total": {
              "type": "integer",
              "description": "Total number of items",
              "minimum": 0
            },
            "limit": {
              "type": "integer",
              "description": "Items per page",
              "minimum": 1
            },
            "offset": {
              "type": "integer",
              "description": "Current offset",
              "minimum": 0
            },
            "has_more": {
              "type": "boolean",
              "description": "Whether more items are available"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "description": "Machine-readable error code",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "message": {
          "type": "string",
          "description": "Human-readable error message"
        },
        "suggestion": {
          "type": "string",
          "description": "Suggested action to resolve the error"
        },
        "help_command": {
          "type": "string",
          "description": "Command to get more help"
        },
        "details": {
          "type": "object",
          "description": "Additional error context"
        }
      }
    },
    "observation_kind": {
      "type": "string",
      "enum": ["decision", "incident", "note", "meeting", "todo", "snippet", "tool_call"],
      "description": "Type of observation"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    }
  }
}
